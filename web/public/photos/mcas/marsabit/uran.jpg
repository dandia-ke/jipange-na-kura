		<style type="text/css" id="wp-custom-css">
			#header {
    border-bottom: none;
    background-color: #2bc52b;
}

#intro {
    background-image: url(./images/heading-bg.jpg);
    background-repeat: no-repeat;
    background-position: center bottom;
    background-size: cover;
    border-top: none;
    padding: 20px 0px 20px 0px;
    text-align: center;
    margin-top: 0px;
}
#header-sticky .header-links .sub-menu a:hover, #header-sticky .header-links .sub-menu .current-menu-item a {
    color: #fff !important;
    background-color: #2bc52b !important;
}
#sub-footer {
    background-color: #333;
    border-top: none;
    color: #fff;
    DISPLAY: NONE;
}

#pre-header {
    background-color: #ffffff;
    border-bottom: none;
}

#content {
    clear: both;
    margin: 0;
    padding: 0px 10px;
    overflow: hidden;
}
a {
    color: #159525 !important;

}

.vc_btn3.vc_btn3-color-juicy-pink, .vc_btn3.vc_btn3-color-juicy-pink.vc_btn3-style-flat {
    background-color: #30302e !important;
    color: #fff !important;
